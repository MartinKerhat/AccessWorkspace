# Access Workspace — environment template
#
# Copy this file to `.env` and fill in real values for local development:
#     cp .env.example .env
#
# `.env` is gitignored and must never be committed. In non-local environments
# (Kubernetes, etc.) these variables are injected by the deployment instead:
#   - non-secret values via a ConfigMap
#   - secret values via a Secret
# The application reads only from the environment; it has no baked-in secrets.

# ============================================================================
# SECRETS — required, no defaults. The backend refuses to start without these.
# ============================================================================

# AES key used to encrypt inline secret values before storing them in Postgres.
# Generate a unique random value per deployment, e.g.:  openssl rand -base64 32
RESOURCE_SECRET_KEY=

# Postgres password. Used both by the postgres container and to build
# DATABASE_URL for the backend in docker-compose (local dev only).
POSTGRES_PASSWORD=

# In production you typically run Postgres elsewhere (managed service / another
# host) and do NOT use the compose postgres container. In that case set the full
# connection string directly and use TLS. docker-compose does not use this — it
# builds DATABASE_URL from POSTGRES_PASSWORD — but the app reads it directly.
# DATABASE_URL=postgres://appuser:PASSWORD@db.example.com:5432/access_workspace?sslmode=require

# Microsoft Entra client secret. Required only when AUTH_MODE=entra.
ENTRA_CLIENT_SECRET=

# ============================================================================
# CORE — safe defaults shown; override only if needed.
# ============================================================================

# Environment marker. Only the value "production" (case-insensitive) switches
# on runtime protection: the app then refuses to start if SEED_ON_START or
# RESET_DB_ON_START is true. Any other value (development, staging, ci, test,
# empty, ...) runs unrestricted. Leave empty/unset for local dev.
APP_ENV=development

# Address the backend HTTP server listens on.
HTTP_ADDR=:8080

# Public URL of the frontend (used for CORS / redirects).
FRONTEND_URL=http://localhost:4173

# Auth mode: "dev" or "entra" (Microsoft sign-in). Local username/password
# login works in either mode; "dev" only changes the reported label/hint.
AUTH_MODE=dev

# Dev-mode default user label.
DEFAULT_DEV_USER=alice

# Database schema lifecycle.
# AUTO_MIGRATE runs migrations on startup (safe in production).
# SEED_ON_START inserts demo data — dev only; must be false in production.
# RESET_DB_ON_START wipes the schema — dev only; must be false in production.
AUTO_MIGRATE=true
RESET_DB_ON_START=false
SEED_ON_START=false

# ============================================================================
# FIRST-ADMIN BOOTSTRAP — creates the initial admin when the DB has no users.
# ============================================================================
# On the first startup against an empty user table, an admin is created from
# these values so you can sign in without touching the database. Idempotent:
# once any user exists this does nothing. Username + password must be set
# together (password >= 8 chars). Provide the password via a Secret in prod.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_DISPLAY_NAME=
BOOTSTRAP_ADMIN_EMAIL=

# ============================================================================
# MICROSOFT ENTRA (non-secret) — required when AUTH_MODE=entra.
# ============================================================================

ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_AUTHORITY=https://login.microsoftonline.com
ENTRA_REDIRECT_URI=http://localhost:8080/api/auth/microsoft/callback
ENTRA_GROUP_SOURCE=graph
# Optional JSON mapping of directly-assigned rights.
ENTRA_DIRECT_RIGHTS_JSON=

# ============================================================================
# DOWNLOADABLE ARTIFACTS (launcher + browser extensions)
# ============================================================================
# Where the app lists downloadable builds from. See artifacts/README.md.
#   local — a directory (dev: the mounted ./artifacts folder; prod: a mounted
#           volume). The frontend serves the files at /downloads/.
#   blob  — an Azure Blob container, listed over REST; downloads use blob URLs.
ARTIFACTS_SOURCE=local
# local source: filesystem root containing the category folders.
ARTIFACTS_DIR=/data/downloads
# blob source: container URL and optional SAS token (needs list + read).
ARTIFACTS_BLOB_CONTAINER_URL=
ARTIFACTS_BLOB_SAS=

# ============================================================================
# BROWSER EXTENSION STORE LINKS (non-secret, optional)
# ============================================================================
# When set, the store listing becomes the primary install action and direct
# download becomes the fallback.
CHROME_WEB_STORE_URL=
FIREFOX_EXTENSION_URL=

# ============================================================================
# FRONTEND BUILD (non-secret) — baked in at build time by docker-compose.
# ============================================================================

VITE_API_BASE_URL=http://localhost:8080/api
